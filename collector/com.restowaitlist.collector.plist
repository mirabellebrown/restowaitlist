<!--
  macOS LaunchAgent: collector on the :00/:15/:30/:45 grid, 11:00–23:45 local time.
  Machine timezone should be America/New_York. collect.py also enforces the same
  quiet window (midnight–11am ET) so a TZ drift cannot scrape overnight.

  Install / reload:
    cp collector/com.restowaitlist.collector.plist ~/Library/LaunchAgents/
    launchctl bootout gui/$(id -u)/com.restowaitlist.collector 2>/dev/null || true
    launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.restowaitlist.collector.plist
-->
