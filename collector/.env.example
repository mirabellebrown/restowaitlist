# RestoWaitlist collector configuration. Copy to `.env` and fill in.
# run.sh sources this file before launching the collector.

# --- GitHub Pages publish (primary hosting path) ---
# Local checkout of the `gh-pages` branch. Each successful cycle merges
# readings into data/waits.json and pushes, updating:
#   https://jdelpego.github.io/restowaitlist/
# Leave empty to skip Pages publish.
RWL_SITE_DIR=/Users/jdelpego/.restowaitlist/site

# --- Optional Cloudflare POST (her Worker, if deployed) ---
# Local preview:  http://127.0.0.1:8787
# Production:     https://restowaitlist.<your-subdomain>.workers.dev
RWL_API_BASE=
RWL_COLLECTOR_TOKEN=

# Restaurant slug (matches the seeded Din Tai Fung record).
RWL_SLUG=din-tai-fung-new-york-3

# Party sizes recorded each cycle. 5 is Yelp's "5+" bucket (no distinct 6).
RWL_PARTY_SIZES=2,3,4,5

# Yelp URLs. {size} is substituted per party size.
RWL_WAIT_URL=https://www.yelp.com/waitlist/din-tai-fung-new-york-3?party_size={size}
# Optional warm-up navigation before the waitlist loads (empty = go direct,
# which is the proven-good, lowest-request path).
RWL_WARMUP_URL=

# Persistent Chrome profile — keeps the DataDome cookie warm between runs.
RWL_PROFILE_DIR=/Users/jdelpego/.restowaitlist/chrome-profile

# Optional: inject a datadome cookie exported from your real Chrome session.
# Run: .venv/bin/python import_yelp_cookie.py
RWL_COOKIE_FILE=/Users/jdelpego/.restowaitlist/datadome.json
# Which Chrome profile to read the cookie from (Default, Profile 1, …).
RWL_CHROME_PROFILE=Default

# Leave false: headless Chrome is reliably blocked by DataDome.
RWL_HEADLESS=false
# Set true to scrape and print without publishing.
RWL_DRY_RUN=false

# Active window (America/New_York). Default skips midnight–11am ET.
RWL_ACTIVE_TZ=America/New_York
RWL_ACTIVE_START_HOUR=11
RWL_ACTIVE_END_HOUR=24
